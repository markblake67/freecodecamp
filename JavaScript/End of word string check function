function confirmEnding(stringOne, stringCheck) { 
  const startIndex = stringOne.length - stringCheck.length; //gets the index of the last word from the legnth of the first string - the length of the string check
  let lastSentence = stringOne.slice(startIndex) //slices the last word off probably could merge with start index variable
  if (lastSentence === stringCheck) {
    return true
  }
  return false
}
  
