let lunches = []

function addLunchToEnd(arr, str) {
  arr.push(str);
  console.log(`${str} added to the end of the lunch menu.`)
  return arr
}

function addLunchToStart(arr, str) {
  arr.unshift(str);
  console.log(`${str} added to the start of the lunch menu.`)
  return arr
}

function removeLastLunch(arrTwo) {
  let last = arrTwo.pop()
  if (arrTwo.length > 0) {
    console.log(`${last} removed from the end of the lunch menu.`)
  } else {
    console.log("No lunches to remove.")
  }
  return arrTwo
}

function removeFirstLunch(remFirst) {
  let first = remFirst.shift()
  if (remFirst.length > 0) {
    console.log(`${first} removed from the start of the lunch menu.`)
  } else {
    console.log("No lunches to remove.")
  }
  return remFirst
}

function getRandomLunch(arrRand) {
  let length = arrRand.length;
  let randNum = Math.floor(Math.random() * length);
  if (length === 0) {
    console.log("No lunches available.");
  } else {
    console.log("Randomly selected lunch: " + arrRand[randNum]);
  }
}

function showLunchMenu(menu) {
  if (menu.length > 0) {
    console.log(`Menu items: ${menu.join(", ")}`)
  } else {
    console.log("The menu is empty.")
  }
}

